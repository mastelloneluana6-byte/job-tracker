# Copy to .env and set your real credentials.
# Neon: add uselibpqcompat=true (avoids pg driver SSL deprecation noise with sslmode=require).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?uselibpqcompat=true&sslmode=require&schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/job_tracker?schema=public"
